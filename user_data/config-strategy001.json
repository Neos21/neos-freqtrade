{
  "$schema": "https://schema.freqtrade.io/schema.json",
  "max_open_trades": 3,
  "stake_currency": "JPY",
  "stake_amount": 7000,
  "tradable_balance_ratio": 0.99,
  "fiat_display_currency": "JPY",
  "dry_run": false,
  "dry_run_wallet": 35000,
  "cancel_open_orders_on_exit": false,
  "trading_mode": "spot",
  "margin_mode": "",
  "unfilledtimeout": {
    "entry": 10,
    "exit": 10,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },
  "entry_pricing": {
    "price_side": "other",
    "use_order_book": false,
    "order_book_top": 1
  },
  "exit_pricing": {
    "price_side": "other",
    "use_order_book": false,
    "order_book_top": 1
  },
  "exchange": {
    "name": "bitbank",
    "key": "【BitBank API キー】",
    "secret": "【BitBank API シークレット】",
    "ccxt_config": {
      "enableRateLimit": true
    },
    "ccxt_async_config": {
      "enableRateLimit": true
    },
    "pair_whitelist": [
      "BTC/JPY",
      "ETH/JPY",
      "XRP/JPY",
      "SOL/JPY",
      "BNB/JPY"
    ],
    "pair_blacklist": [],
    "enable_ws": false
  },
  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],
  "telegram": {
    "enabled": false,
    "token": "",
    "chat_id": ""
  },
  "api_server": {
    "enabled": true,
    "listen_ip_address": "0.0.0.0",
    "listen_port": 8080,
    "verbosity": "error",
    "enable_openapi": false,
    "jwt_secret_key": "【JWT シークレットキー】",
    "ws_token": "【トークン】",
    "CORS_origins": [],
    "username": "【WebUI ログイン時のユーザ名】",
    "password": "【WebUI ログイン時のパスワード】"
  },
  "bot_name": "freqtrade-strategy001",
  "initial_state": "running",
  "force_entry_enable": false,
  "internals": {
    "process_throttle_secs": 5
  },
  "db_url": "sqlite:////freqtrade/user_data/tradesv3-strategy001.sqlite"
}
